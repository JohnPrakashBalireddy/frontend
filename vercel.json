{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/ride-on-demand/browser",
  "env": {
    "NG_APP_ENV": "production"
  },
  "functions": {
    "api/ssr.js": {
      "runtime": "nodejs20.x",
      "memory": 256,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/ssr.js"
    }
  ]
}

